# Frontend public variables (technical brief §11).
# The Supabase anon key is NOT a secret (real security lives in RLS),
# but it is injected per environment so builds are not tied to a project.
# Copy this file to .env and fill in. NEVER put service-role keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_TURNSTILE_SITE_KEY=
