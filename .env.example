# Variables públicas del frontend (brief técnico §11).
# La anon key de Supabase NO es un secreto (la seguridad real está en RLS),
# pero se inyecta por entorno para no atar el build a un proyecto concreto.
# Copia este archivo a .env y rellena. NUNCA pongas aquí claves service-role.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_TURNSTILE_SITE_KEY=
